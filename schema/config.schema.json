{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ChowDPa02K/jellyfin-remora/blob/main/schema/config.schema.json",
  "title": "Jellyfin Remora configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["config-version", "remora", "jellyfin"],
  "properties": {
    "config-version": { "const": 2 },
    "restapi": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "listen": { "type": "string", "default": "127.0.0.1" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8095 },
        "unix-socket": { "type": "string" }
      }
    },
    "remora": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server-start-timeout": { "$ref": "#/$defs/duration" },
        "server-stop-timeout": { "$ref": "#/$defs/duration" },
        "io-timeout": { "$ref": "#/$defs/duration" },
        "recovery-successes": { "type": "integer", "minimum": 1 },
        "data-dir": { "type": "string" },
        "monitoring": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "interval": { "$ref": "#/$defs/duration" },
            "jellyfin-api": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "interval": { "$ref": "#/$defs/duration" },
                "failure-threshold": { "type": "integer", "minimum": 1 }
              }
            },
            "user-login": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "interval": { "$ref": "#/$defs/duration" },
                "user": { "type": "string" },
                "password": { "type": "string" }
              }
            }
          }
        },
        "logs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string" },
            "level": { "enum": ["debug", "info", "warning", "warn", "error"] },
            "rotation-time": { "$ref": "#/$defs/duration" },
            "rotation-size-mb": { "type": "integer", "minimum": 1 },
            "preserve-time": { "$ref": "#/$defs/duration" }
          }
        }
      }
    },
    "disk": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": { "enum": ["physical", "smb", "nfs"] },
          "device": { "type": "string" },
          "uuid": { "type": "string" },
          "options": { "type": "string" },
          "user": { "type": "string" },
          "password": { "type": "string" },
          "target": { "type": "string" },
          "permission": { "enum": ["r", "rw"] },
          "heartbeat": { "type": "integer", "minimum": 1 },
          "hearbeat": { "type": "integer", "minimum": 1, "deprecated": true },
          "failure-threshold": { "type": "integer", "minimum": 1, "default": 1 }
        }
      }
    },
    "jellyfin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "data-dir", "config-dir", "cache-dir", "log-dir"],
      "properties": {
        "path": { "type": "string" },
        "run-as-user": { "type": "string" },
        "run-as-group": { "type": "string" },
        "data-dir": { "type": "string" },
        "config-dir": { "type": "string" },
        "cache-dir": { "type": "string" },
        "log-dir": { "type": "string" },
        "web-dir": { "type": "string" },
        "parameters": { "type": "object", "additionalProperties": true },
        "general": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "settings": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "server-name": { "type": ["string", "null"] } }
            },
            "paths": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "cache-path": { "type": ["string", "null"] },
                "metadata-path": { "type": ["string", "null"] }
              }
            },
            "performance": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "parallel-library-scan-tasks-limit": { "type": ["integer", "null"], "minimum": 0 },
                "parallel-image-encoding-limit": { "type": ["integer", "null"], "minimum": 0 }
              }
            }
          }
        },
        "branding": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enable-splash-screen": { "type": ["boolean", "null"] },
            "splash-screen-image": { "type": ["string", "null"] },
            "login-disclaimer": { "type": ["string", "null"] },
            "custom-css-code": { "type": ["string", "null"] }
          }
        },
        "playback": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "transcoding": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "transcode-path": { "type": ["string", "null"] },
                "enable-fallback-fonts": { "type": ["boolean", "null"] },
                "fallback-font-folder-path": { "type": ["string", "null"] }
              }
            }
          }
        },
        "networking": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "server-address-settings": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "local-http-port-number": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "local-https-port-number": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "enable-https": { "type": "boolean" },
                "base-url": { "type": ["string", "null"] },
                "bind-to-local-network-address": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "array", "items": { "type": "string" } },
                    { "type": "null" }
                  ]
                }
              }
            },
            "ip-protocols": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enable-ipv4": { "type": ["boolean", "null"] },
                "enable-ipv6": { "type": ["boolean", "null"] }
              }
            }
          }
        }
      }
    },
    "init": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user", "password"],
      "properties": {
        "server-name": { "type": "string" },
        "display-language": { "type": "string", "description": "Exact visible label from the Jellyfin Web display-language selection, not an API code" },
        "user": { "type": "string", "minLength": 1 },
        "password": { "type": "string", "minLength": 1 },
        "preferred-metadata-language": { "type": "string", "description": "Exact visible label from the Jellyfin Web metadata-language selection, not an ISO code" },
        "preferred-metadata-region": { "type": "string", "description": "Exact visible label from the Jellyfin Web country/region selection, not a region code" },
        "allow-remote-connections": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "duration": {
      "oneOf": [
        { "type": "integer", "minimum": 1, "description": "Seconds" },
        { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?(?:ns|us|µs|ms|s|m|h|d|w)$" }
      ]
    }
  }
}
